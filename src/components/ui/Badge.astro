---
interface Props {
  text: string;
  variant?: 'default' | 'accent';
}

const { text, variant = 'default' } = Astro.props;

const variantClass = variant === 'accent'
  ? 'border border-accent/30 text-accent'
  : 'bg-surface-2 text-neutral-2';
---

<span class:list={['inline-block rounded-sm px-3 py-1 font-mono text-[12px] uppercase tracking-[0.08em]', variantClass]}>
  {text}
</span>
