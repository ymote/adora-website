---
---

<button
  id="theme-toggle"
  class="flex items-center gap-1.5 rounded-sm border border-surface-3 px-2 py-1 transition-colors duration-300 hover:border-neutral-1"
  aria-label="Toggle theme"
>
  <!-- Black mode icon (terminal/monitor) -->
  <svg class="theme-icon theme-icon-black size-4 text-neutral-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15A2.25 2.25 0 002.25 6.75v10.5A2.25 2.25 0 004.5 19.5z" />
  </svg>
  <!-- Dark mode icon (moon/ocean) -->
  <svg class="theme-icon theme-icon-dark hidden size-4 text-neutral-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
  </svg>
  <!-- Light mode icon (sun) -->
  <svg class="theme-icon theme-icon-light hidden size-4 text-neutral-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
  </svg>
  <span id="theme-label" class="font-mono text-[10px] uppercase tracking-[0.08em] text-neutral-2">black</span>
</button>

<script>
  const themes = ['black', 'dark', 'light'] as const;
  type Theme = typeof themes[number];

  const toggle = document.getElementById('theme-toggle');
  const label = document.getElementById('theme-label');
  const icons = {
    black: toggle?.querySelector('.theme-icon-black'),
    dark: toggle?.querySelector('.theme-icon-dark'),
    light: toggle?.querySelector('.theme-icon-light'),
  };

  function setTheme(theme: Theme) {
    if (theme === 'black') {
      document.documentElement.removeAttribute('data-theme');
    } else {
      document.documentElement.setAttribute('data-theme', theme);
    }
    localStorage.setItem('theme', theme);

    // Update icons
    Object.values(icons).forEach((icon) => icon?.classList.add('hidden'));
    icons[theme]?.classList.remove('hidden');

    // Update label
    if (label) label.textContent = theme;
  }

  // Initialize
  const stored = localStorage.getItem('theme') as Theme | null;
  if (stored && themes.includes(stored)) {
    setTheme(stored);
  }

  // Cycle: black -> dark -> light -> black
  toggle?.addEventListener('click', () => {
    const current = (localStorage.getItem('theme') || 'black') as Theme;
    const idx = themes.indexOf(current);
    const next = themes[(idx + 1) % themes.length];
    setTheme(next);
  });
</script>
