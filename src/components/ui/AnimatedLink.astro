---
interface Props {
  href: string;
  external?: boolean;
  class?: string;
}

const { href, external = false, class: className } = Astro.props;
const attrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a
  href={href}
  class:list={['link-animated font-mono text-[12px] uppercase leading-none tracking-[0.08em]', className]}
  {...attrs}
>
  <slot />
</a>
