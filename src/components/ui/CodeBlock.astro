---
interface Props {
  code: string;
  title?: string;
  class?: string;
}

const { code, title = 'terminal', class: className } = Astro.props;
---

<div class:list={['overflow-hidden rounded-sm border border-surface-3 bg-surface-1', className]}>
  <!-- Terminal header -->
  <div class="flex items-center gap-2 border-b border-surface-3 px-4 py-2.5">
    <span class="size-2 rounded-full bg-surface-3" />
    <span class="size-2 rounded-full bg-surface-3" />
    <span class="size-2 rounded-full bg-surface-3" />
    <span class="ml-2 font-mono text-[15px] text-neutral-1">{title}</span>
  </div>
  <!-- Code -->
  <pre class="overflow-x-auto p-4"><code class="font-mono text-[15px] leading-relaxed text-text" set:html={code} /></pre>
</div>
