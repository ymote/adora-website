---
import Button from 'components/ui/Button.astro';
import Badge from 'components/ui/Badge.astro';
---

<section class="hero-scene relative flex min-h-screen items-center overflow-hidden py-20">
  <!-- Background: Renaissance wireframe composition -->
  <div class="absolute inset-0 z-0">
    <img src="/images/hero-wireframe.svg" alt="" class="h-full w-full object-cover" loading="eager" />
  </div>

  <!-- Text directly on background -->
  <div class="relative z-10 w-full px-4 lg:px-9">
    <div class="mx-auto max-w-7xl text-center">
      <h1>
        <span class="block text-[56px] leading-[1] tracking-[-0.05em] text-title md:text-[80px] lg:text-[100px] 2xl:text-[120px]">
          Agentic
        </span>
        <span class="mt-1 block text-[28px] leading-[1.1] tracking-[-0.03em] text-white/90 md:text-[40px] lg:text-[48px] 2xl:text-[56px]">
          Dataflow-Oriented Robotic Architecture
        </span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-[18px] leading-relaxed text-white/80 md:text-[20px] lg:text-[22px]">
        100% Rust framework for real-time robotics and AI. 10-17x faster than ROS2
        with zero-copy shared memory, 4 communication patterns, and production-grade
        fault tolerance.
      </p>

      <!-- Stats bar -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 font-mono text-[15px] uppercase tracking-[0.08em] text-white/60 md:gap-x-6 md:text-[16px]">
        <span>10-17x faster</span>
        <span class="text-white/20">|</span>
        <span>4 patterns</span>
        <span class="text-white/20">|</span>
        <span>4 languages</span>
        <span class="text-white/20">|</span>
        <span>zero-copy</span>
        <span class="text-white/20">|</span>
        <span>open source</span>
      </div>

      <!-- CTAs -->
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <Button href="#quickstart">Get Started</Button>
        <Button href="https://github.com/dora-rs/adora" variant="outline" external>
          GitHub
        </Button>
      </div>
    </div>
  </div>
</section>
