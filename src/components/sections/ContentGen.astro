---
import Section from 'components/layout/Section.astro';
import Container from 'components/layout/Container.astro';

const features = [
  { name: 'adora record', description: 'Capture live messages from any running dataflow to .adorec files' },
  { name: 'adora replay', description: 'Replay recorded data at any speed — 0.1x for debugging or 10x for regression tests' },
  { name: 'Node substitution', description: 'Swap out nodes during replay to test new logic against recorded inputs' },
  { name: 'Offline debugging', description: 'Debug entire dataflows without running hardware or physical sensors' },
];
---

<Section padY="lg">
  <Container>
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-6">
      <div class="lg:col-span-5" data-animate>
        <p class="font-mono text-[12px] uppercase tracking-[0.08em] text-neutral-2">Record & Replay</p>
        <h2 class="mt-3 text-[28px] tracking-[-0.03em] md:text-[36px] lg:text-[48px]">
          Capture, replay, debug
        </h2>
        <p class="mt-4 text-[16px] leading-relaxed text-neutral-2">
          Record all dataflow messages to .adorec files. Replay offline at any speed
          with node substitution for regression testing and time-travel debugging.
        </p>

        <div class="mt-8 flex flex-col gap-4">
          {features.map((f) => (
            <div class="flex items-start gap-4 border border-surface-3 bg-surface-1 p-4 transition-colors duration-300 hover:border-neutral-1">
              <span class="shrink-0 font-mono text-[14px] text-accent">{f.name}</span>
              <p class="text-[14px] text-neutral-2">{f.description}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="lg:col-span-7" data-animate>
        <p class="font-mono text-[12px] uppercase tracking-[0.08em] text-neutral-2">Workflow</p>
        <h3 class="mt-3 text-[20px] tracking-[-0.01em]">Time-travel debugging</h3>
        <p class="mt-2 text-[14px] leading-relaxed text-neutral-2">
          Record once in the field, replay endlessly in the lab. Swap individual nodes
          to test new algorithms against real-world data without deploying to hardware.
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          {['.adorec format', 'variable speed', 'node substitution', 'offline mode', 'regression testing', 'CI integration', 'data inspection', 'timestamp replay', 'selective recording', 'multi-node capture'].map((s) => (
            <span class="rounded-sm border border-surface-3 bg-surface-1 px-3 py-1.5 font-mono text-[11px] text-neutral-2 transition-colors duration-300 hover:border-neutral-1 hover:text-accent">
              {s}
            </span>
          ))}
        </div>
      </div>
    </div>
  </Container>
</Section>
