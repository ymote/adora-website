---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<details class="group border-b border-surface-3 py-6">
  <summary class="flex cursor-pointer items-center justify-between text-[18px] tracking-[-0.01em] text-text transition-colors duration-300 hover:text-accent lg:text-[20px]">
    {question}
    <span class="ml-4 shrink-0 font-mono text-[16px] text-neutral-2 transition-transform duration-300 group-open:rotate-45">
      +
    </span>
  </summary>
  <p class="mt-4 max-w-2xl text-[14px] leading-relaxed text-neutral-2 lg:text-[16px]">
    {answer}
  </p>
</details>
