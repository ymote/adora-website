---
import SvgSection from 'components/ui/SvgSection.astro';
import PipelineFlow from 'components/PipelineFlow.jsx';

const patterns = [
  {
    name: 'Topic',
    color: 'text-accent',
    description: 'Fire-and-forget pub/sub for sensor data, periodic status, and events',
  },
  {
    name: 'Service',
    color: 'text-heading',
    description: 'Request/reply with UUID correlation. Client sends request, server returns exactly one response',
  },
  {
    name: 'Action',
    color: 'text-title',
    description: 'Long-running goals with periodic feedback and cancellation support',
  },
  {
    name: 'Streaming',
    color: 'text-accent',
    description: 'Continuous data with session/segment/chunk metadata and queue flushing for real-time interruption',
  },
];
---

<SvgSection bgSrc="/images/bg-deep-panel.png">
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-8">
    <div class="glass-panel">
      <p class="font-mono text-[12px] uppercase tracking-[0.08em] text-neutral-2">Communication Patterns</p>
      <h2 class="mt-3 text-[28px] tracking-[-0.03em] md:text-[36px] lg:text-[48px]">
        Four ways to<br />communicate
      </h2>
      <p class="mt-4 text-[16px] leading-relaxed text-neutral-2">
        Beyond pub/sub. Adora provides Topic, Service, Action, and Streaming patterns
        via well-known metadata keys. No daemon or YAML changes required.
      </p>

      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
        {patterns.map((p) => (
          <div class="border border-surface-3 bg-surface-1 p-4">
            <p class:list={['font-mono text-[12px] uppercase tracking-[0.08em]', p.color]}>{p.name}</p>
            <p class="mt-2 text-[14px] leading-relaxed text-neutral-2">{p.description}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div class="glass-panel">
        <PipelineFlow client:only="react" />
      </div>

      <div class="mt-4 grid grid-cols-2 gap-4">
        <div class="glass-panel text-center">
          <span class="font-mono text-[28px] leading-none text-text-bright">4</span>
          <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.08em] text-neutral-2">Comm patterns</p>
        </div>
        <div class="glass-panel text-center">
          <span class="font-mono text-[28px] leading-none text-text-bright">0</span>
          <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.08em] text-neutral-2">YAML changes needed</p>
        </div>
      </div>
    </div>
  </div>
</SvgSection>
