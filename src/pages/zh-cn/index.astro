---
import Layout from 'layouts/Layout.astro';
import Architecture from 'components/sections/Architecture.astro';
import DeepResearch from 'components/sections/DeepResearch.astro';
import ToolSystem from 'components/sections/ToolSystem.astro';
import Memory from 'components/sections/Memory.astro';
import ContentGen from 'components/sections/ContentGen.astro';
import Security from 'components/sections/Security.astro';
import Performance from 'components/sections/Performance.astro';
import Comparison from 'components/sections/Comparison.astro';
import UseCases from 'components/sections/UseCases.astro';
import FAQ from 'components/sections/FAQ.astro';
import zhStats from 'data/zh-cn/stats.json';
import zhFeatures from 'data/zh-cn/features.json';
import zhFaq from 'data/zh-cn/faq.json';
---

<Layout
  title="Adora — 智能体数据流机器人架构"
  description="100% Rust 实时机器人和 AI 应用框架。零拷贝共享内存，比 ROS2 快 10-17 倍。支持 Rust、Python、C、C++。"
>
  <section class="hero-scene relative flex min-h-screen items-end overflow-hidden pb-12 pt-20 lg:pb-16">
    <div class="absolute inset-0 z-0">
      <div class="h-full w-full" style="background: linear-gradient(135deg, #0A0A0F 0%, #1C1C28 40%, rgba(0, 212, 170, 0.08) 100%);"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent" />
    </div>

    <div class="relative z-10 w-full px-4 lg:px-9">
      <div class="mx-auto max-w-7xl text-center">
        <span class="inline-block rounded-sm border border-accent/50 bg-accent/10 px-2 py-0.5 font-mono text-[15px] uppercase tracking-[0.08em] text-white">开源</span>

        <h1 class="mt-4 text-[28px] leading-[1.1] tracking-[-0.03em] text-white md:text-[42px] 2xl:text-[52px]">
          智能体数据流<br />机器人架构
        </h1>

        <p class="mx-auto mt-5 max-w-xl text-[15px] leading-relaxed text-white/70 lg:text-[16px]">
          100% Rust 实时机器人和 AI 应用框架。零拷贝共享内存 + Apache Arrow，
          比 ROS2 快 10-17 倍。4 种通信模式，生产级容错，分布式部署。
        </p>

        <div class="mt-5 flex flex-wrap items-center justify-center gap-x-3 gap-y-1 font-mono text-[15px] uppercase tracking-[0.08em] text-white/50 md:gap-x-4">
          <span>10-17x 更快</span>
          <span class="text-white/20">|</span>
          <span>4 种模式</span>
          <span class="text-white/20">|</span>
          <span>4 种语言</span>
          <span class="text-white/20">|</span>
          <span>零拷贝</span>
          <span class="text-white/20">|</span>
          <span>开源</span>
        </div>

        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a href="#quickstart" class="inline-block rounded-sm bg-accent px-4 py-2 font-mono text-[16px] uppercase tracking-[0.08em] text-white transition-colors hover:bg-accent-dark">开始使用</a>
          <a href="https://github.com/dora-rs/adora" target="_blank" rel="noopener noreferrer" class="inline-block rounded-sm border border-white/20 px-4 py-2 font-mono text-[16px] uppercase tracking-[0.08em] text-white transition-colors hover:bg-white/20 hover:text-accent">GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-bg-secondary px-4 py-12 lg:px-9 lg:py-16">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-5 md:gap-6">
        {zhStats.map((stat) => (
          <div class="text-center">
            <p class="font-mono text-[24px] text-text-bright">{stat.value}</p>
            <p class="font-mono text-[16px] uppercase tracking-[0.08em] text-neutral-2">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="px-4 py-16 lg:px-9 lg:py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 lg:mb-16">
        <p class="font-mono text-[16px] uppercase tracking-[0.08em] text-neutral-2">核心能力</p>
        <h2 class="mt-3 text-[28px] tracking-[-0.03em] text-text-bright md:text-[36px] lg:text-[48px]">为什么选择 Adora</h2>
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        {zhFeatures.map((feature) => (
          <div class="glass-box">
            {feature.stat && (
              <p class="font-mono text-[28px] text-accent">{feature.stat}</p>
            )}
            {feature.statLabel && (
              <p class="font-mono text-[15px] uppercase tracking-[0.08em] text-neutral-2">{feature.statLabel}</p>
            )}
            <h3 class="mt-3 text-[18px] tracking-[-0.01em]">{feature.title}</h3>
            <p class="mt-2 text-[16px] leading-relaxed text-neutral-2">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Architecture />
  <DeepResearch />
  <ToolSystem />
  <Memory />
  <ContentGen />
  <Security />
  <Performance />
  <Comparison />
  <UseCases />

  <section id="quickstart" class="bg-bg-secondary px-4 py-16 lg:px-9 lg:py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 lg:mb-16">
        <p class="font-mono text-[16px] uppercase tracking-[0.08em] text-neutral-2">快速开始</p>
        <h2 class="mt-3 text-[28px] tracking-[-0.03em] text-text-bright md:text-[36px] lg:text-[48px]">5 分钟开始</h2>
        <p class="mt-4 max-w-xl text-[16px] leading-relaxed text-neutral-2">
          安装 CLI，定义 YAML 数据流，开始处理数据。
        </p>
      </div>

      <div class="mt-8 rounded-xl border border-surface-3 bg-surface-2 p-6">
        <pre class="font-mono text-[15px] leading-relaxed text-neutral-2"><code><span class="text-neutral-1"># 安装 Adora CLI</span>
cargo install adora-cli

<span class="text-neutral-1"># 启动数据流</span>
adora start dataflow.yml

<span class="text-neutral-1"># 查看状态</span>
adora list

<span class="text-neutral-1"># 查看日志</span>
adora logs</code></pre>
      </div>
    </div>
  </section>

  <section class="px-4 py-16 lg:px-9 lg:py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 lg:mb-16">
        <p class="font-mono text-[16px] uppercase tracking-[0.08em] text-neutral-2">常见问题</p>
        <h2 class="mt-3 text-[28px] tracking-[-0.03em] text-text-bright md:text-[36px] lg:text-[48px]">FAQ</h2>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {zhFaq.map((item) => (
          <details class="glass-panel group">
            <summary class="flex cursor-pointer items-center justify-between gap-3">
              <h3 class="text-[16px] tracking-[-0.01em] text-text-bright">{item.question}</h3>
              <p class="text-neutral-2 text-[16px]">+</p>
            </summary>
            <p class="mt-3 text-[16px] leading-relaxed text-neutral-2">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bg-secondary px-4 py-16 lg:px-9 lg:py-24">
    <div class="mx-auto max-w-xl text-center">
      <h2 class="text-[28px] tracking-[-0.03em] text-text-bright md:text-[36px] lg:text-[48px]">
        5 分钟构建<br class="hidden md:block" />你的第一个数据流
      </h2>
      <p class="mx-auto mt-4 max-w-md text-[16px] leading-relaxed text-neutral-2">
        安装 CLI，用 YAML 定义节点，开始处理数据。
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href="/book" class="inline-block rounded-sm bg-accent px-4 py-2 font-mono text-[16px] uppercase tracking-[0.08em] text-white transition-colors hover:bg-accent-dark">阅读手册</a>
        <a href="https://github.com/dora-rs/adora" target="_blank" rel="noopener noreferrer" class="inline-block rounded-sm border border-white/20 px-4 py-2 font-mono text-[16px] uppercase tracking-[0.08em] text-white transition-colors hover:bg-white/20 hover:text-accent">GitHub</a>
      </div>
    </div>
  </section>
</Layout>
